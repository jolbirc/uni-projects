@page
@model AirbnbGuesthouseSite.Pages.Room.IndexModel

@{
    ViewData["Title"] = "INDEX | ";
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<form asp-area="Identity"
      asp-page="/Account/Logout"
      asp-route-returnUrl="@Url.Page("/Index")"
      method="post">
    <button type="submit" id="admin-logout">Logout</button>
</form>
<div class="admin-wrapper">
    <h1>Edit Rooms</h1>

    <p>
        <a asp-page="Create">Add Room</a>
    </p>
    <table class="table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Room) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.RoomName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RoomDescription)
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                    @* <a asp-page="./Details" asp-route-id="@item.Id">Details</a> | *@
                    <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
