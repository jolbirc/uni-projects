@page
@model AirbnbGuesthouseSite.Pages.Room.DeleteModel

@{
    ViewData["Title"] = "DELETE ROOM | ";
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<div class="admin-wrapper">
    <h1>Delete</h1>

    <h3>Are you sure you want to delete this room?</h3>
    <div>
        <dl class="row">
            <dt class="col-sm-2">
                Room Name
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Room.RoomName)
            </dd>
            <dt class="col-sm-2">
                Room Description
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Room.RoomDescription)
            </dd>
        </dl>
        <br>
        <form method="post">
            <input type="hidden" asp-for="Room.Id" />
            <input type="submit" value="Delete" class="btn btn-danger" />
            <br><br>
            <a asp-page="./Index">Back to Rooms</a>
        </form>
    </div>
</div>
